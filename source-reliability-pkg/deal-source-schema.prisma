// Add this to packages/database/prisma/schema.prisma

enum SourceReliabilityLabel {
  NEW_SOURCE
  TRUSTED_SOURCE
  GOOD_SOURCE
  SLOW_RESPONSE
  BAD_INFO_BEFORE
  LOW_QUALITY
  CLOSED_BEFORE
  BLACKLIST
}

enum SourceType {
  OWN
  JV
  FACEBOOK
  BIRD_DOG
  WHOLESALER
  AGENT
  SMS
  MANUAL
}

model DealSource {
  id                    String   @id @default(uuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])

  // Identity — used for matching/deduplication
  sourceName            String?
  sourceType            String   @default("JV")
  phone                 String?
  email                 String?
  company               String?
  facebookProfileUrl    String?
  facebookGroupName     String?

  // Reliability
  reliabilityScore      Int      @default(50)
  reliabilityLabel      String   @default("NEW_SOURCE")
  sourceNotes           String?

  // Deal history (auto-tracked)
  totalDealsSubmitted   Int      @default(0)
  activeDeals           Int      @default(0)
  deadDeals             Int      @default(0)
  dealsThatGotInterest  Int      @default(0)
  dealsThatGotOffers    Int      @default(0)
  dealsAssigned         Int      @default(0)
  dealsClosed           Int      @default(0)

  // Accuracy tracking
  badInfoCount          Int      @default(0)
  missingInfoFrequency  Float    @default(0)  // 0-1, percentage of deals with missing info
  hadContractConfirmed  Boolean  @default(false)
  permissionToMarket    Boolean  @default(false)

  // Communication
  averageResponseTimeMin Int?    // minutes
  sendsPhotosQuickly    Boolean  @default(false)
  providesAccessQuickly Boolean  @default(false)
  answersQuestionsClearly Boolean @default(false)
  goesGhostCount        Int      @default(0)

  // Revenue
  closedRevenueGenerated Float   @default(0)

  // Flags
  isBlacklisted         Boolean  @default(false)
  isVerified            Boolean  @default(false)

  lastDealSubmittedAt   DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  deals                 Deal[]

  @@index([organizationId])
  @@index([phone])
  @@index([facebookProfileUrl])
  @@index([email])
}
